<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">travel-access.ddns.net</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
            <!-- Bundle your server certificate in res/raw/travel_access_cert -->
            <certificates src="@raw/travel_access_cert" />
        </trust-anchors>
    </domain-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>